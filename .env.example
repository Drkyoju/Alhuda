# Supabase project URL (public — safe to commit; protected by RLS).
SUPABASE_URL=https://smcyaqwxbmhshhhhdece.supabase.co

# Supabase key. For server-side scripts (scripts/apply_*.py) use a SERVICE ROLE
# key from Supabase → Project Settings → API → service_role secret. NEVER commit
# this value. For client-side (index.html) use the publishable anon key — that
# one is safe to expose because RLS enforces access control.
SUPABASE_KEY=replace-me-with-service-role-key

# Optional override for the source quiz_app.html used by sync scripts.
# Defaults to <project>/quiz_app.html or the first CLI argument.
# QUIZ_HTML=/absolute/path/to/quiz_app.html
